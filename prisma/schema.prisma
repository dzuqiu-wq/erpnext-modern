// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- 用户与权限 (RBAC) ---

model User {
  id           String    @id @default(uuid())
  name         String?
  email        String    @unique
  password     String?
  // RBAC 角色：admin=系统管理员, sales=销售, warehouse=仓库管理, finance=财务
  role         String    @default("SALES") // ADMIN, SALES, WAREHOUSE, FINANCE, PURCHASE
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs      AuditLog[]
  activities     CustomerActivity[]
  opportunities  Opportunity[]
  assignedTickets Ticket[] @relation("AssignedTickets")

  @@map("users")
}

// --- 审计日志 ---

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  // 操作人 ID
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // 动作描述，如 "UPDATE", "DELETE", "CREATE"
  entityName  String   // 操作的表名，如 "Customer", "SalesOrder"
  entityId    String?  // 被操作记录的 ID
  details     Json?    // 修改前后对比数据
  ipAddress   String?  // 客户端 IP
  userAgent   String?  // 客户端 UA
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

// --- CRM 基础底盘 ---

model Customer {
  id        String   @id @default(uuid())
  name      String // 客户名称或公司名称
  email     String?
  phone     String?
  company   String?

  // CRM 扩展字段
  level     String   @default("C") // 客户等级: A, B, C (A=大客户)
  status    String   @default("Lead") // 客户状态: Lead(线索), Prospect(意向), Active(活跃), Churned(流失)
  source    String?  // 来源渠道: 展会, 官网, 朋友推荐, 广告等
  tags      Json?    // 标签数组，如 ["重要客户", "制造业", "华南"]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  salesOrders   SalesOrder[]
  contacts       CustomerContact[]
  activities     CustomerActivity[]
  opportunities  Opportunity[]
  tickets        Ticket[]  // 客户相关的工单

  @@map("customers")
}

// 客户联系人（多对一）
model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  name        String   // 联系人姓名
  position    String?  // 职位
  phone       String?  // 电话
  wechat      String?  // 微信
  email       String?
  isPrimary   Boolean  @default(false) // 是否主联系人
  
  createdAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("customer_contacts")
}

// 客户沟通记录（多对一）
model CustomerActivity {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  type        String   // 沟通类型: 电话, 邮件, 拜访, 微信, 其他
  content     String   // 沟通内容摘要
  followUpBy  String?  // 跟进人 ID
  followUpByUser User? @relation(fields: [followUpBy], references: [id])
  
  activityDate DateTime @default(now()) // 沟通日期
  nextFollowUp DateTime? // 下次跟进日期
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("customer_activities")
}

model Item {
  id           String   @id @default(uuid())
  itemCode     String   @unique // 商品编码，如 ITEM-0001
  itemName     String // 商品名称
  description  String? // 详细描述
  standardRate Float    @default(0.0) // 标准售价
  stockUom     String   @default("PCS") // 库存单位: PCS, KG, Box 等
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrderItems    SalesOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockLedgers       StockLedger[]
  stockBalances      StockBalance[]

  @@map("items")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String // 供应商名称
  email     String?
  phone     String?
  status    String   @default("Active") // Active, Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  orderNumber String   @unique // 例如: PO-2026-0001
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  status      String   @default("Draft") // Draft, Submitted, Completed, Cancelled
  totalAmount Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id])
  quantity        Float         @default(1.0)
  rate            Float         @default(0.0) // 采购进价
  amount          Float         @default(0.0)

  @@map("purchase_order_items")
}

model SalesOrder {
  id            String    @id @default(uuid())
  orderNumber   String    @unique // 例如: SO-2026-0001
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  status        String    @default("Draft") // 状态: Draft, Submitted, Completed, Cancelled
  totalAmount   Float     @default(0.0) // 商品总额（折扣前）
  discountAmount Float    @default(0.0) // 整单折扣金额
  taxRate       Float     @default(0.0) // 税率百分比，如 13.0 表示 13%
  grandTotal    Float     @default(0.0) // 含税总价 = (商品总额 - 折扣) * (1 + 税率/100)
  deliveryDate  DateTime? // 交货日期
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items SalesOrderItem[]
  tickets Ticket[]  // 关联的售后工单

  @@map("sales_orders")
}

model SalesOrderItem {
  id           String     @id @default(uuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  itemId       String
  item         Item       @relation(fields: [itemId], references: [id])
  warehouseId  String?
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  quantity     Float      @default(1.0)
  rate         Float      @default(0.0) // 实际成交单价
  amount       Float      @default(0.0) // quantity * rate

  @@map("sales_order_items")
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String // 仓库名称，如"成品库"
  code      String   @unique // 仓库编码，如"WH-001"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockLedgers     StockLedger[]
  stockBalances    StockBalance[]
  salesOrderItems  SalesOrderItem[]

  @@map("warehouses")
}

model StockLedger {
  id          String    @id @default(uuid())
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  qtyChange   Float // 数量变动：正数表示入库，负数表示出库
  rate        Float    @default(0.0) // 本次交易的入库或出库单价
  voucherType String // 凭证类型，如 "Purchase Receipt", "Sales Delivery", "Stock Entry"
  voucherNo   String // 关联的单据编号，如 "PO-2026-0001"
  createdAt   DateTime  @default(now())

  @@map("stock_ledgers")
}

model StockBalance {
  id            String    @id @default(uuid())
  itemId        String
  item          Item      @relation(fields: [itemId], references: [id])
  warehouseId  String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  actualQty     Float     @default(0.0) // 当前实际结存数量
  stockValue    Float     @default(0.0) // 库存总价值
  valuationRate Float     @default(0.0) // 移动加权平均单价
  reservedQty  Float     @default(0.0) // 已预留数量(防超卖)
  updatedAt     DateTime  @updatedAt

  @@unique([itemId, warehouseId]) // 同一个仓库里的同一个商品只能有一条结存记录
  @@map("stock_balances")
}

model Account {
  id          String   @id @default(uuid())
  name        String   @unique // 科目名称，例如 "银行存款", "应收账款", "主营业务收入"
  type        String   // 资产(Asset), 负债(Liability), 权益(Equity), 收入(Income), 支出(Expense)
  isGroup     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalLines JournalEntryAccount[]

  @@map("accounts")
}

model JournalEntry {
  id            String   @id @default(uuid())
  entryNumber   String   @unique // 凭证号，例如 JV-2026-0001
  referenceType String?  // 关联单据类型，例如 "SalesOrder", "PurchaseOrder"
  referenceId   String?  // 关联单据ID
  postingDate   DateTime @default(now())
  totalDebit    Float    @default(0.0) // 总借方金额
  totalCredit   Float    @default(0.0) // 总贷方金额
  createdAt     DateTime @default(now())

  lines         JournalEntryAccount[]

  @@map("journal_entries")
}

model JournalEntryAccount {
  id             String       @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Float        @default(0.0) // 借方
  credit         Float        @default(0.0) // 贷方

  @@map("journal_entry_accounts")
}

// --- 生产管理模块 ---

model WorkOrder {
  id              String   @id @default(cuid())
  workOrderNo     String   @unique // 生产单号 (如 HB26050033)
  salesOrderId    String?  // 关联的销售订单
  customerId      String?  // 关联客户
  itemId          String   // 生产的成品物料 ID
  itemName        String?  // 成品物料名称
  itemCode        String?  // 成品物料编码
  quantity        Int
  startDate       DateTime // 下单/开始日期
  endDate         DateTime // 出货/完工日期
  status          String   @default("Draft") // Draft, InProgress, Completed

  // 动态生产参数 (存储频率、锣牙、空载电流等非通用字段)
  customAttributes Json?

  maker           String?  // 制表人
  auditor         String?  // 审核人

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// --- 发货管理模块 ---

model DeliveryNote {
  id              String   @id @default(cuid())
  deliveryNo      String   @unique // 送货单号 (如 HB2026050019)
  customerId      String
  customerName    String?  // 客户名称
  salesOrderId    String?
  deliveryDate    DateTime
  totalAmount     Float    @default(0)
  status          String   @default("Draft") // Draft, Printed, Delivered

  maker           String?  // 制单人
  notes           String?  // 备注

  items           DeliveryNoteItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeliveryNoteItem {
  id              String   @id @default(cuid())
  deliveryNoteId  String
  deliveryNote    DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  itemId          String
  itemName        String
  itemCode        String?  // 物料编号
  specifications  String?  // 规格
  unit            String   @default("PCS")
  quantity        Int
  unitPrice       Float
  taxRate         Float    @default(13)
  taxAmount       Float
  lineTotal       Float
}

// --- 销售商机管道 (CRM Pipeline) ---

// 商机阶段定义
enum OpportunityStage {
  Qualification  // 资质初审
  Discovery      // 需求挖掘
  Proposal       // 方案报价
  Negotiation    // 谈判合同
  Won            // 赢单成单
  Lost           // 输单流失
}

model Opportunity {
  id            String   @id @default(cuid())
  name          String   // 商机名称 (例如：XX集团模具采购项目)
  customerId    String   // 关联客户
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  // 商机阶段：Qualification(资质初审), Discovery(需求挖掘), Proposal(方案报价), Negotiation(谈判合同), Won(赢单成单), Lost(输单流失)
  stage         String   @default("Qualification") 
  
  value         Float    @default(0)   // 预计金额
  probability   Int      @default(10)  // 赢单概率 (0-100)
  closeDate     DateTime // 预计结单日期
  
  ownerId       String   // 负责人/跟进销售 ID
  owner         User     @relation(fields: [ownerId], references: [id])
  
  notes         String?  // 备注/商机背景说明
  customFields  Json?    // 扩展参数
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([stage])
  @@index([ownerId])
  @@index([customerId])

  @@map("opportunities")
}

// --- 售后工单体系 (Customer Support) ---

model Ticket {
  id          String   @id @default(cuid())
  ticketNo    String   @unique // 工单号 (如 TK-2605-0001)
  title       String   // 故障/咨询概要
  description String?  // 详细描述
  
  status      String   @default("Open")   // 状态: Open, InProgress, Resolved, Closed
  priority    String   @default("Medium") // 优先级: Low, Medium, High, Urgent
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  assigneeId  String?  // 处理人 (客服/工程师)
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id])
  
  // 业财客一体化核心桥梁：强制关联底层 ERP 单据
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  
  dueDate     DateTime? // SLA 承诺解决期限
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([priority])

  @@map("tickets")
}

// ============================================================
// Phase 4: BI 大屏轻量级 OLAP 快照引擎
// ============================================================

model MetricsSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @db.Date // 记录日期（精确到天）
  metricType  String   // 指标类型: SALES_FUNNEL, TICKET_SLA, REVENUE_FORECAST
  value       Float    // 核心数值
  payload     Json?    // 详细的维度数据 (如各个阶段的商机数量分布)

  createdAt   DateTime @default(now())

  @@unique([date, metricType])
  @@index([metricType, date])

  @@map("metrics_snapshots")
}